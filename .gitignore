# Terraform state and sensitive files
*.tfstate
*.tfstate.*
*.tfstate.backup
.terraform/
.terraform.lock.hcl
terraform.tfvars        # contains your email — never commit
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# SSH keys — never commit private keys
lab-key
lab-key.pem
*.pem
*.ppk

# Lambda build artefacts
lambda/*.zip
lambda/__pycache__/
lambda/*.pyc

# Screenshots — too large for git, store in cloud storage
screenshots/*.png
screenshots/*.jpg

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
/terraform
